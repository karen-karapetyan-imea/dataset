# Shared database URL for importers and sync scripts (auto-loaded by sync_*.sh).
# psycopg format (scripts normalize postgresql+asyncpg:// automatically).
# Render external connections require sslmode=require.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Lakehouse local data lake root (bronze/, silver/, gold/ directories).
LAKEHOUSE_DATA_ROOT=/home/samvel/project-data/dataset
HTML_CRAWLER_ROOT=/home/samvel/project-data/dataset/html-crawler



# Path to html-crawler project for read-only parser imports.
HTML_CRAWLER_ROOT=/home/samvel/dataset/html-crawler

# Spark configuration for lakehouse jobs.
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=4g
SPARK_SHUFFLE_PARTITIONS=200
SPARK_WAREHOUSE_DIR=/home/samvel/project-data/dataset/spark-warehouse
SPARK_LOG_LEVEL=WARN
